# Backend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/surety
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=surety

# Server
NODE_ENV=development
PORT=5000

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# OTP
OTP_SECRET=your_otp_secret_key
OTP_WINDOW=2

# Email Service (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Payment Gateway - Campay
CAMPAY_API_KEY=your_campay_api_key
CAMPAY_API_URL=https://api.campay.net
CAMPAY_SANDBOX=true

# Commission
COMMISSION_RATE=0.04
BUYER_COMMISSION_RATE=0.02
SELLER_COMMISSION_RATE=0.02

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=pdf,doc,docx,jpg,png,jpeg

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
