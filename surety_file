async function createTransaction(){
  if(!currentUser)return showToast('Please sign in','error');
  const role=document.getElementById('txn-role').value;
  const counterparty=document.getElementById('txn-counterparty').value.trim();
  const desc=document.getElementById('txn-desc').value.trim();
  const amount=parseFloat(document.getElementById('txn-amount').value);
  const delivery=document.getElementById('txn-delivery').value;
  const notes=document.getElementById('txn-notes').value.trim();
  if(!counterparty)return showToast("Please enter the other party's email",'error');
  if(!desc)return showToast('Please describe the product or service','error');
  if(!amount||amount<500)return showToast('Minimum transaction amount is 500 XAF','error');
  const btn=document.getElementById('create-txn-btn');
  btn.disabled=true;btn.textContent='Creating...';
  const{data:cpProfile}=await db.from('profiles').select('id,full_name,email').eq('email',counterparty).single();
  const txnData={
    seller_id:role==='seller'?currentUser.id:cpProfile?.id||null,
    buyer_id:role==='buyer'?currentUser.id:cpProfile?.id||null,
    seller_email:role==='seller'?currentProfile?.email:counterparty,
    buyer_email:role==='buyer'?currentProfile?.email:counterparty,
    description:desc,amount:amount,
    fee:Math.round(amount*0.03),
    delivery_method:delivery,notes:notes,
    status:'pending',
    created_at:new Date().toISOString(),
    updated_at:new Date().toISOString()
  };
  const{data,error}=await db.from('transactions').insert(txnData).select().single();
  if(error){showToast('Error: '+error.message,'error');btn.disabled=false;btn.textContent='🔒 Create Secure Transaction';return;}
  showToast('Transaction created! 🎉','success');
  btn.disabled=false;btn.textContent='🔒 Create Secure Transaction';
  document.getElementById('txn-counterparty').value='';
  document.getElementById('txn-desc').value='';
  document.getElementById('txn-amount').value='';
  document.getElementById('txn-notes').value='';
  document.getElementById('fee-display').style.display='none';
  await viewTransaction(data.id);
}

async function viewTransaction(id){
  currentTxnId=id;
  const{data:t}=await db.from('transactions').select('*').eq('id',id).single();
  if(!t)return showToast('Transaction not found','error');
  const isSeller=t.seller_id===currentUser?.id;
  const statusSteps=['pending','escrow','delivered','completed'];
  const currentStep=statusSteps.indexOf(t.status);
  const stepLabels=['Created','Paid','Delivered','Completed'];
  const fillPct=Math.max(0,(currentStep/(statusSteps.length-1))*100);
  let stepsHTML=stepLabels.map((label,i)=>{
    const done=i<currentStep;
    const current=i===currentStep;
    return `<div class="progress-step">
      <div class="progress-dot ${done?'done':current?'current':''}">
        ${done?'<span style="color:white;font-weight:700">✓</span>':`<span style="color:${current?'var(--blue)':'rgba(255,255,255,0.4)'};font-size:0.75rem;font-weight:700">${i+1}</span>`}
      </div>
      <div class="progress-label">${label}</div>
    </div>`;
  }).join('');
  let actionsHTML='';
  if(t.status==='pending'){
    if(!isSeller){actionsHTML+=`<button class="btn accent" onclick="goToPayment('${t.id}')">💳 Pay Now into Escrow</button>`;}
    else{actionsHTML+=`<div style="font-size:0.85rem;color:var(--gray);padding:12px;background:var(--off);border-radius:10px">⏳ Waiting for buyer to pay into escrow</div>`;}
    actionsHTML+=`<button class="btn secondary" onclick="cancelTransaction('${t.id}')">Cancel</button>`;
  }else if(t.status==='escrow'){
    if(isSeller){actionsHTML+=`<button class="btn primary" onclick="markDelivered('${t.id}')">📦 Mark as Delivered</button>`;}
    else{actionsHTML+=`<div style="font-size:0.85rem;color:var(--gray);padding:12px;background:var(--off);border-radius:10px">⏳ Waiting for seller to deliver</div>`;}
    actionsHTML+=`<button class="btn secondary" onclick="openDispute('${t.id}')">⚠️ Report Issue</button>`;
  }else if(t.status==='delivered'){
    if(!isSeller){
      actionsHTML+=`<button class="btn accent" onclick="confirmDelivery('${t.id}')">✅ Yes, I Received It — Release Payment</button>`;
      actionsHTML+=`<button class="btn secondary" onclick="openDispute('${t.id}')">❌ I Have an Issue</button>`;
    }else{actionsHTML+=`<div style="font-size:0.85rem;color:var(--gray);padding:12px;background:var(--off);border-radius:10px">⏳ Waiting for buyer to confirm receipt</div>`;}
  }else if(t.status==='completed'){
    actionsHTML=`<div style="text-align:center;padding:16px;background:#F0FFF4;border-radius:12px;color:#16A34A;font-weight:700">✅ Transaction Completed — Payment Released</div>`;
  }else if(t.status==='disputed'){
    actionsHTML=`<div style="text-align:center;padding:16px;background:#FFF5F5;border-radius:12px;color:var(--danger);font-weight:700">⚠️ Dispute in Progress — Surety team reviewing</div>`;
  }else if(t.status==='cancelled'){
    actionsHTML=`<div style="text-align:center;padding:16px;background:var(--off);border-radius:12px;color:var(--gray);font-weight:700">Transaction Cancelled</div>`;
  }
  const paymentLink=`${window.location.origin}${window.location.pathname}?pay=${t.id}`;
  document.getElementById('txn-detail-content').innerHTML=`
    <div class="txn-detail-header">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">
        <div>
          <div style="font-size:0.78rem;opacity:0.6;margin-bottom:4px;text-transform:uppercase;letter-spacing:0.05em">${isSeller?'You are selling':'You are buying'}</div>
          <div class="txn-detail-amount">${formatAmount(t.amount)} XAF</div>
          <div class="txn-detail-desc">${t.description}</div>
        </div>
        <span class="status-badge ${t.status}" style="font-size:0.8rem;padding:5px 14px">${statusLabel(t.status)}</span>
      </div>
      <div style="position:relative;margin-top:20px">
        <div class="progress-steps">
          <div class="progress-fill" style="width:${fillPct}%"></div>
          ${stepsHTML}
        </div>
      </div>
    </div>
    <div class="card" style="margin-bottom:16px">
      <div class="card-header"><span class="card-title">Transaction Details</span></div>
      <div class="card-body">
        <div class="detail-grid">
          <div class="detail-field"><div class="detail-field-label">Transaction ID</div><div class="detail-field-val" style="font-family:monospace;font-size:0.78rem">${t.id.substr(0,16)}...</div></div>
          <div class="detail-field"><div class="detail-field-label">Date Created</div><div class="detail-field-val">${formatDate(t.created_at)}</div></div>
          <div class="detail-field"><div class="detail-field-label">Seller</div><div class="detail-field-val">${t.seller_email||'—'}</div></div>
          <div class="detail-field"><div class="detail-field-label">Buyer</div><div class="detail-field-val">${t.buyer_email||'—'}</div></div>
          <div class="detail-field"><div class="detail-field-label">Amount</div><div class="detail-field-val">${formatAmount(t.amount)} XAF</div></div>
          <div class="detail-field"><div class="detail-field-label">Surety Fee (3%)</div><div class="detail-field-val">${formatAmount(t.fee)} XAF</div></div>
          <div class="detail-field"><div class="detail-field-label">Delivery Method</div><div class="detail-field-val">${deliveryLabel(t.delivery_method)}</div></div>
          <div class="detail-field"><div class="detail-field-label">Seller Receives</div><div class="detail-field-val" style="color:var(--success)">${formatAmount(t.amount)} XAF</div></div>
        </div>
        ${t.notes?`<div class="detail-field" style="margin-top:12px"><div class="detail-field-label">Notes</div><div class="detail-field-val">${t.notes}</div></div>`:''}
      </div>
    </div>
    ${t.status==='pending'&&isSeller?`
    <div class="card" style="margin-bottom:16px">
      <div class="card-header"><span class="card-title">Payment Link for Buyer</span></div>
      <div class="card-body">
        <p style="font-size:0.85rem;color:var(--gray);margin-bottom:12px">Share this link with the buyer so they can pay into escrow:</p>
        <div style="background:var(--off);border:1.5px solid var(--border);border-radius:10px;padding:12px;font-family:monospace;font-size:0.75rem;word-break:break-all;color:var(--blue)">${paymentLink}</div>
        <button class="btn secondary sm" style="margin-top:10px" onclick="copyLink('${paymentLink}')">Copy Payment Link</button>
      </div>
    </div>`:''}
    <div class="action-bar">${actionsHTML}</div>`;
  switchView('view-txn-detail');
}

