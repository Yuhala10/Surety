async function releasePayment(id){
  closeModal();
  const{data:t}=await db.from('transactions').select('*').eq('id',id).single();
  if(!t)return showToast('Transaction not found','error');
  const{error}=await db.from('transactions').update({status:'completed',completed_at:new Date().toISOString(),updated_at:new Date().toISOString()}).eq('id',id);
  if(error)return showToast('Error: '+error.message,'error');
  if(t.seller_id){
    const{data:sp}=await db.from('profiles').select('wallet_balance,trust_score').eq('id',t.seller_id).single();
    await db.from('profiles').update({wallet_balance:(sp?.wallet_balance||0)+t.amount,trust_score:Math.min(100,(sp?.trust_score||0)+5)}).eq('id',t.seller_id);
  }
  if(t.buyer_id){
    const{data:bp}=await db.from('profiles').select('trust_score').eq('id',t.buyer_id).single();
    await db.from('profiles').update({trust_score:Math.min(100,(bp?.trust_score||0)+3)}).eq('id',t.buyer_id);
  }
  showToast('Payment released to seller! 🎉','success');
  await loadProfile();
  await viewTransaction(id);
}

