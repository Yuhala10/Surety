async function processPayment(){
  const phone=document.getElementById('pay-phone').value.trim();
  if(!phone)return showToast('Please enter your MoMo phone number','error');
  if(!currentPayTxn)return showToast('Transaction not found','error');
  const btn=document.getElementById('pay-btn');
  btn.disabled=true;btn.textContent='⏳ Processing...';
  try{
    const total=currentPayTxn.amount+currentPayTxn.fee;
    const response=await fetch('https://api.notchpay.co/payments/initialize',{
      method:'POST',
      headers:{'Authorization':NOTCHPAY_PUBLIC,'Content-Type':'application/json','Accept':'application/json'},
      body:JSON.stringify({
        amount:total,currency:'XAF',
        description:`Surety Escrow: ${currentPayTxn.description}`,
        reference:`SUR_${currentPayTxn.id}_${Date.now()}`,
        callback:window.location.origin+window.location.pathname,
        customer:{phone,email:currentUser?.email||'buyer@surety.cm',name:currentProfile?.full_name||'Buyer'}
      })
    });
    const result=await response.json();
    if(result.code===201||result.status==='Accepted'){
      await db.from('transactions').update({
        status:'escrow',
        payment_reference:result.transaction?.reference||result.reference,
        buyer_id:currentUser?.id,
        buyer_email:currentUser?.email,
        updated_at:new Date().toISOString()
      }).eq('id',currentPayTxn.id);
      showToast('Payment initiated! Check your phone for MoMo prompt. 📱','success');
      if(result.authorization_url||result.transaction?.authorization_url){
        window.open(result.authorization_url||result.transaction?.authorization_url,'_blank');
      }
      btn.disabled=false;btn.textContent='Pay Securely Now';
      showPage('page-dashboard');
      await viewTransaction(currentPayTxn.id);
    }else{
      showToast(result.message||'Payment failed. Please try again.','error');
      btn.disabled=false;btn.textContent='Pay Securely Now';
    }
  }catch(err){
    showToast('Payment error: '+err.message,'error');
    btn.disabled=false;btn.textContent='Pay Securely Now';
  }
}

