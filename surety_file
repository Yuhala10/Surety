async function processWithdrawal(){
  const phone=document.getElementById('withdraw-phone')?.value?.trim();
  const amount=parseFloat(document.getElementById('withdraw-amount')?.value);
  const balance=currentProfile?.wallet_balance||0;
  if(!phone)return showToast('Enter your MoMo number','error');
  if(!amount||amount<=0)return showToast('Enter withdrawal amount','error');
  if(amount>balance)return showToast('Insufficient balance','error');
  closeModal();
  await db.from('profiles').update({wallet_balance:balance-amount}).eq('id',currentUser.id);
  showToast('Withdrawal submitted. Funds arrive in 1-5 minutes.','success');
  await loadProfile();
  await loadWallet();
}

function formatAmount(n){return(n||0).toLocaleString('fr-CM')}
function formatDate(d){if(!d)return'—';return new Date(d).toLocaleDateString('fr-CM',{day:'numeric',month:'short',year:'numeric'})}

async function checkUrlParams(){
  const params=new URLSearchParams(window.location.search);
  const payId=params.get('pay');
  if(payId){
    const{data:t}=await db.from('transactions').select('*').eq('id',payId).single();
    if(t&&t.status==='pending'){
      currentPayTxn=t;
      const total=t.amount+(t.fee||Math.round(t.amount*0.03));
      document.getElementById('pay-amount').textContent=formatAmount(total)+' XAF';
      document.getElementById('pay-desc').textContent=t.description;
      document.getElementById('pay-breakdown-amount').textContent=formatAmount(t.amount)+' XAF';
      document.getElementById('pay-breakdown-fee').textContent=formatAmount(t.fee||Math.round(t.amount*0.03))+' XAF';
      document.getElementById('pay-breakdown-total').textContent=formatAmount(total)+' XAF';
      showPage('page-payment');
    }
  }
}

initAuth().then(()=>checkUrlParams());
</script>
