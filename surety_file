<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Surety – Trust. Every Transaction.</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
<style>
:root {
  --green: #1E3A8A;
  --green-light: #2563EB;
  --accent: #3B82F6;
  --blue: #0F172A;
  --blue-mid: #1E3A8A;
  --white: #FFFFFF;
  --off: #F4F7F5;
  --gray: #6B7B8D;
  --border: #E2EAE6;
  --danger: #E53E3E;
  --warning: #F6AD55;
  --success: #22C55E;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--off);color:var(--blue);min-height:100vh}
.toast{position:fixed;top:20px;right:20px;z-index:9999;padding:14px 20px;border-radius:12px;font-size:0.875rem;font-weight:600;color:white;max-width:320px;box-shadow:0 8px 30px rgba(0,0,0,0.15);transform:translateX(400px);transition:transform 0.3s ease}
.toast.show{transform:translateX(0)}
.toast.success{background:var(--success)}
.toast.error{background:var(--danger)}
.toast.info{background:var(--blue)}
.page{display:none;min-height:100vh}
.page.active{display:block}
nav{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:64px;background:white;border-bottom:1px solid var(--border);box-shadow:0 1px 8px rgba(0,0,0,0.04)}
.logo{display:flex;align-items:center;gap:10px;cursor:pointer}
.logo-text{font-family:'Syne',sans-serif;font-size:1.15rem;color:var(--blue)}
.logo-text span{color:var(--accent)}
.nav-right{display:flex;align-items:center;gap:12px}
.nav-user{font-size:0.8rem;color:var(--gray);font-weight:500}
.btn-nav{padding:8px 16px;border-radius:8px;font-size:0.82rem;font-weight:600;cursor:pointer;border:none;transition:all 0.2s}
.btn-nav.primary{background:var(--accent);color:white}
.btn-nav.ghost{background:var(--off);color:var(--blue);border:1px solid var(--border)}
.hero{min-height:100vh;background:linear-gradient(135deg,var(--blue) 0%,var(--blue-mid) 60%,var(--accent) 100%);display:flex;flex-direction:column}
.landing-nav{display:flex;align-items:center;justify-content:space-between;padding:20px 6%;position:relative;z-index:10}
.landing-logo{display:flex;align-items:center;gap:10px}
.landing-logo-text{font-family:'Syne',sans-serif;font-size:1.3rem;color:white}
.landing-logo-text span{color:var(--accent)}
.landing-nav-btns{display:flex;gap:12px}
.btn-landing-ghost{padding:10px 20px;background:rgba(255,255,255,0.1);color:white;border:1px solid rgba(255,255,255,0.25);border-radius:10px;font-size:0.875rem;font-weight:600;cursor:pointer;transition:all 0.2s}
.btn-landing-primary{padding:10px 20px;background:var(--accent);color:white;border:none;border-radius:10px;font-size:0.875rem;font-weight:700;cursor:pointer;transition:all 0.2s}
.hero-body{flex:1;display:flex;align-items:center;justify-content:center;padding:60px 6%;text-align:center}
.hero-inner{max-width:700px}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(59,130,246,0.15);border:1px solid rgba(59,130,246,0.3);border-radius:100px;padding:6px 16px;margin-bottom:28px}
.hero-badge span{font-size:0.75rem;color:var(--accent);font-weight:600;text-transform:uppercase;letter-spacing:0.06em}
.pulse{width:6px;height:6px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
.hero-h1{font-family:'Syne',sans-serif;font-size:clamp(2.8rem,6vw,4.5rem);color:white;line-height:1.05;letter-spacing:-0.03em;margin-bottom:20px}
.hero-h1 .accent{color:var(--accent)}
.hero-sub{font-size:1.1rem;color:rgba(255,255,255,0.65);line-height:1.65;margin-bottom:40px}
.hero-btns{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:60px}
.btn-hero-primary{padding:16px 32px;background:var(--accent);color:white;border-radius:14px;font-weight:700;font-size:1rem;border:none;cursor:pointer;transition:all 0.2s;box-shadow:0 4px 24px rgba(59,130,246,0.4)}
.btn-hero-ghost{padding:16px 32px;background:rgba(255,255,255,0.08);color:white;border-radius:14px;font-weight:600;font-size:1rem;border:1px solid rgba(255,255,255,0.2);cursor:pointer;transition:all 0.2s}
.hero-stats{display:flex;justify-content:center;gap:48px;padding-top:40px;border-top:1px solid rgba(255,255,255,0.1)}
.stat-num{font-family:'Syne',sans-serif;font-size:1.8rem;color:white;font-weight:800}
.stat-lbl{font-size:0.78rem;color:rgba(255,255,255,0.45);margin-top:2px}
.how-section{padding:80px 6%;background:white}
.how-inner{max-width:1000px;margin:0 auto;text-align:center}
.section-tag{font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--accent);margin-bottom:10px}
.section-h2{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,3.5vw,2.5rem);color:var(--blue);letter-spacing:-0.02em;margin-bottom:10px}
.section-sub{font-size:0.95rem;color:var(--gray);line-height:1.65;margin-bottom:48px}
.steps-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px}
.step-card{padding:28px 20px;background:var(--off);border-radius:16px;border:1.5px solid var(--border);text-align:center;transition:all 0.2s}
.step-card:hover{border-color:var(--accent);transform:translateY(-3px)}
.step-n{width:48px;height:48px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:800;color:white}
.step-card h3{font-size:0.95rem;font-weight:700;color:var(--blue);margin-bottom:8px}
.step-card p{font-size:0.8rem;color:var(--gray);line-height:1.55}
.problem-section{padding:80px 6%;background:var(--blue)}
.problem-inner{max-width:1000px;margin:0 auto}
.problems-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:40px}
.prob-card{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:16px;padding:28px}
.prob-icon{font-size:1.8rem;margin-bottom:14px}
.prob-card h3{font-size:0.95rem;color:white;font-weight:700;margin-bottom:8px}
.prob-card p{font-size:0.8rem;color:rgba(255,255,255,0.5);line-height:1.55}
.cta-section{padding:80px 6%;background:var(--accent);text-align:center}
.cta-section h2{font-family:'Syne',sans-serif;font-size:clamp(1.8rem,3.5vw,2.5rem);color:white;margin-bottom:12px}
.cta-section p{color:rgba(255,255,255,0.8);font-size:1rem;margin-bottom:32px}
.btn-white{padding:14px 32px;background:white;color:var(--accent);border-radius:12px;font-weight:700;font-size:0.95rem;border:none;cursor:pointer;transition:all 0.2s}
.auth-page{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:linear-gradient(135deg,var(--blue) 0%,var(--blue-mid) 60%,var(--accent) 100%)}
.auth-card{background:white;border-radius:24px;padding:40px;width:100%;max-width:420px;box-shadow:0 24px 60px rgba(0,0,0,0.2)}
.auth-logo{display:flex;align-items:center;gap:10px;margin-bottom:28px;justify-content:center}
.auth-logo-text{font-family:'Syne',sans-serif;font-size:1.3rem;color:var(--blue)}
.auth-logo-text span{color:var(--accent)}
.auth-title{font-family:'Syne',sans-serif;font-size:1.5rem;color:var(--blue);margin-bottom:6px;text-align:center}
.auth-sub{font-size:0.875rem;color:var(--gray);text-align:center;margin-bottom:28px}
.form-group{margin-bottom:16px}
.form-label{display:block;font-size:0.8rem;font-weight:600;color:var(--blue);margin-bottom:6px}
.form-input{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.875rem;color:var(--blue);outline:none;transition:border-color 0.2s;font-family:'Inter',sans-serif;background:var(--off)}
.form-input:focus{border-color:var(--accent);background:white}
.btn-full{width:100%;padding:13px;background:var(--accent);color:white;border-radius:10px;font-size:0.9rem;font-weight:700;border:none;cursor:pointer;transition:all 0.2s;margin-top:8px}
.btn-full:disabled{opacity:0.6;cursor:not-allowed}
.auth-switch{text-align:center;margin-top:20px;font-size:0.82rem;color:var(--gray)}
.auth-switch a{color:var(--accent);font-weight:600;cursor:pointer}
.auth-back{text-align:center;margin-top:16px}
.auth-back a{font-size:0.8rem;color:var(--gray);cursor:pointer}
.dash-layout{display:flex;min-height:calc(100vh - 64px)}
.sidebar{width:240px;background:white;border-right:1px solid var(--border);padding:24px 16px;flex-shrink:0;position:sticky;top:64px;height:calc(100vh - 64px);overflow-y:auto}
.sidebar-menu{list-style:none}
.sidebar-menu li{margin-bottom:4px}
.sidebar-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;cursor:pointer;font-size:0.875rem;font-weight:500;color:var(--gray);transition:all 0.2s;border:none;background:none;width:100%;text-align:left}
.sidebar-item:hover{background:var(--off);color:var(--blue)}
.sidebar-item.active{background:#EBF0FF;color:var(--accent);font-weight:600}
.sidebar-item .icon{font-size:1.1rem;width:20px;text-align:center}
.sidebar-section{font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:var(--border);padding:16px 12px 6px}
.dash-main{flex:1;padding:32px;overflow-y:auto}
.dash-view{display:none}
.dash-view.active{display:block}
.page-title{font-family:'Syne',sans-serif;font-size:1.5rem;color:var(--blue);font-weight:800;margin-bottom:4px}
.page-sub{font-size:0.875rem;color:var(--gray);margin-bottom:28px}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px}
.stat-card{background:white;border-radius:16px;padding:20px;border:1.5px solid var(--border)}
.stat-card-label{font-size:0.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px}
.stat-card-val{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--blue)}
.stat-card-sub{font-size:0.75rem;color:var(--accent);margin-top:4px;font-weight:500}
.trust-card{background:linear-gradient(135deg,var(--accent),var(--blue));border-radius:20px;padding:28px;color:white;margin-bottom:24px;display:flex;align-items:center;gap:28px}
.trust-ring{width:90px;height:90px;border-radius:50%;background:conic-gradient(rgba(255,255,255,0.9) var(--pct),rgba(255,255,255,0.15) 0);display:flex;align-items:center;justify-content:center;position:relative}
.trust-ring::before{content:'';position:absolute;width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--blue))}
.trust-ring-num{position:relative;z-index:1;font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;color:white}
.trust-info h3{font-family:'Syne',sans-serif;font-size:1.1rem;margin-bottom:4px}
.trust-info p{font-size:0.8rem;opacity:0.7;margin-bottom:12px;line-height:1.5}
.trust-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.15);border-radius:100px;padding:4px 12px;font-size:0.72rem;font-weight:600}
.card{background:white;border-radius:16px;border:1.5px solid var(--border);margin-bottom:20px}
.card-header{padding:20px 24px 0;display:flex;justify-content:space-between;align-items:center}
.card-title{font-size:1rem;font-weight:700;color:var(--blue)}
.card-body{padding:20px 24px}
.txn-list{list-style:none}
.txn-item{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-bottom:1px solid var(--border)}
.txn-item:last-child{border-bottom:none}
.txn-left{display:flex;align-items:center;gap:12px}
.txn-icon{width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.txn-icon.buy{background:#EBF0FF}
.txn-icon.sell{background:#EBF5F0}
.txn-icon.pending{background:#FFF8EB}
.txn-name{font-size:0.875rem;font-weight:600;color:var(--blue)}
.txn-meta{font-size:0.75rem;color:var(--gray);margin-top:2px}
.txn-right{text-align:right}
.txn-amount{font-size:0.9rem;font-weight:700}
.txn-amount.pos{color:var(--success)}
.txn-amount.neg{color:var(--danger)}
.txn-amount.neutral{color:var(--gray)}
.status-badge{display:inline-block;padding:3px 10px;border-radius:100px;font-size:0.7rem;font-weight:700}
.status-badge.pending{background:#FFF8EB;color:#B7791F}
.status-badge.escrow{background:#EBF0FF;color:#3730A3}
.status-badge.delivered{background:#EBF5F0;color:#276749}
.status-badge.completed{background:#F0FFF4;color:#276749}
.status-badge.disputed{background:#FFF5F5;color:var(--danger)}
.status-badge.cancelled{background:var(--off);color:var(--gray)}
.btn{padding:10px 20px;border-radius:10px;font-size:0.875rem;font-weight:600;cursor:pointer;border:none;transition:all 0.2s}
.btn.primary{background:var(--accent);color:white}
.btn.secondary{background:var(--off);color:var(--blue);border:1.5px solid var(--border)}
.btn.danger{background:var(--danger);color:white}
.btn.accent{background:var(--accent);color:white}
.btn.sm{padding:7px 14px;font-size:0.8rem}
.btn.full{width:100%}
.btn:disabled{opacity:0.5;cursor:not-allowed}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.form-select{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.875rem;color:var(--blue);outline:none;transition:border-color 0.2s;font-family:'Inter',sans-serif;background:var(--off);appearance:none}
.form-select:focus{border-color:var(--accent);background:white}
.form-textarea{width:100%;padding:12px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:0.875rem;color:var(--blue);outline:none;transition:border-color 0.2s;font-family:'Inter',sans-serif;background:var(--off);resize:vertical;min-height:80px}
.form-textarea:focus{border-color:var(--accent);background:white}
.form-hint{font-size:0.75rem;color:var(--gray);margin-top:4px}
.amount-display{background:var(--off);border:1.5px solid var(--border);border-radius:12px;padding:16px;margin:16px 0}
.amount-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0}
.amount-label{font-size:0.8rem;color:var(--gray)}
.amount-val{font-size:0.875rem;font-weight:600;color:var(--blue)}
.amount-val.accent{color:var(--accent)}
.amount-val.total{font-size:1rem;font-weight:800;color:var(--blue)}
.divider{border:none;border-top:1px solid var(--border);margin:8px 0}
.txn-detail-header{background:linear-gradient(135deg,var(--blue),var(--blue-mid));border-radius:16px;padding:28px;color:white;margin-bottom:20px}
.txn-detail-amount{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800}
.txn-detail-desc{font-size:0.875rem;opacity:0.7;margin-top:4px}
.progress-steps{display:flex;justify-content:space-between;position:relative}
.progress-steps::before{content:'';position:absolute;top:14px;left:0;right:0;height:2px;background:rgba(255,255,255,0.2);z-index:0}
.progress-fill{position:absolute;top:14px;left:0;height:2px;background:var(--accent);z-index:1;transition:width 0.5s}
.progress-step{text-align:center;position:relative;z-index:2}
.progress-dot{width:28px;height:28px;border-radius:50%;border:2px solid rgba(255,255,255,0.3);background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;margin:0 auto 8px;font-size:0.7rem}
.progress-dot.done{background:var(--accent);border-color:var(--accent)}
.progress-dot.current{background:white;border-color:white}
.progress-label{font-size:0.7rem;opacity:0.7}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.detail-field{padding:14px;background:var(--off);border-radius:12px;border:1px solid var(--border)}
.detail-field-label{font-size:0.72rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:4px}
.detail-field-val{font-size:0.9rem;font-weight:600;color:var(--blue)}
.action-bar{display:flex;gap:12px;margin-top:20px;flex-wrap:wrap}
.wallet-card{background:linear-gradient(135deg,var(--accent),var(--blue-mid));border-radius:20px;padding:32px;color:white;margin-bottom:24px}
.wallet-label{font-size:0.8rem;opacity:0.7;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.05em}
.wallet-amount{font-family:'Syne',sans-serif;font-size:2.4rem;font-weight:800;margin-bottom:4px}
.wallet-currency{font-size:0.9rem;opacity:0.6}
.wallet-actions{display:flex;gap:12px;margin-top:24px}
.btn-wallet{flex:1;padding:12px;border-radius:12px;font-size:0.875rem;font-weight:700;cursor:pointer;border:none;transition:all 0.2s;text-align:center}
.btn-wallet.primary{background:white;color:var(--accent)}
.btn-wallet.ghost{background:rgba(255,255,255,0.15);color:white;border:1px solid rgba(255,255,255,0.25)}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:1000;padding:24px;opacity:0;pointer-events:none;transition:opacity 0.2s}
.modal-overlay.open{opacity:1;pointer-events:all}
.modal{background:white;border-radius:20px;padding:32px;width:100%;max-width:480px;transform:scale(0.95);transition:transform 0.2s}
.modal-overlay.open .modal{transform:scale(1)}
.modal-title{font-family:'Syne',sans-serif;font-size:1.2rem;color:var(--blue);margin-bottom:8px}
.modal-sub{font-size:0.875rem;color:var(--gray);margin-bottom:24px;line-height:1.55}
.modal-actions{display:flex;gap:12px;margin-top:24px}
.empty-state{text-align:center;padding:60px 20px}
.empty-icon{font-size:3rem;margin-bottom:16px}
.empty-title{font-size:1rem;font-weight:700;color:var(--blue);margin-bottom:8px}
.empty-sub{font-size:0.875rem;color:var(--gray);margin-bottom:24px}
.payment-page{min-height:100vh;background:var(--off);display:flex;align-items:center;justify-content:center;padding:24px}
.payment-card{background:white;border-radius:20px;padding:36px;width:100%;max-width:460px;box-shadow:0 12px 40px rgba(0,0,0,0.08)}
.payment-header{text-align:center;margin-bottom:28px}
.payment-lock{font-size:2.5rem;margin-bottom:12px}
.payment-title{font-family:'Syne',sans-serif;font-size:1.3rem;color:var(--blue);margin-bottom:4px}
.payment-sub{font-size:0.875rem;color:var(--gray)}
.payment-amount-box{background:linear-gradient(135deg,var(--accent),var(--blue));border-radius:16px;padding:20px;text-align:center;margin-bottom:24px;color:white}
.payment-amount-label{font-size:0.78rem;opacity:0.7;margin-bottom:4px}
.payment-amount-val{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800}
.payment-amount-desc{font-size:0.8rem;opacity:0.7;margin-top:4px}
.method-label{font-size:0.8rem;font-weight:600;color:var(--blue);margin-bottom:10px}
.method-options{display:flex;gap:10px;margin-bottom:20px}
.method-opt{flex:1;padding:12px;border:2px solid var(--border);border-radius:12px;text-align:center;cursor:pointer;transition:all 0.2s}
.method-opt.selected{border-color:var(--accent);background:#EBF0FF}
.method-dot{width:10px;height:10px;border-radius:50%;margin:0 auto 6px}
.method-name{font-size:0.78rem;font-weight:700;color:var(--blue)}
.profile-header{display:flex;align-items:center;gap:20px;background:white;border-radius:16px;padding:24px;border:1.5px solid var(--border);margin-bottom:20px}
.profile-avatar{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--blue));display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;color:white}
.profile-name{font-family:'Syne',sans-serif;font-size:1.2rem;color:var(--blue);font-weight:800}
.profile-email{font-size:0.82rem;color:var(--gray);margin-top:2px}
.profile-verified{display:inline-flex;align-items:center;gap:5px;background:#EBF0FF;color:var(--accent);font-size:0.72rem;font-weight:700;padding:3px 10px;border-radius:100px;margin-top:6px}
@media(max-width:768px){.sidebar{display:none}.steps-grid{grid-template-columns:1fr 1fr}.problems-grid{grid-template-columns:1fr}.stats-row{grid-template-columns:1fr 1fr}.form-row{grid-template-columns:1fr}.detail-grid{grid-template-columns:1fr}.hero-stats{gap:24px}}
</style>
</head>
